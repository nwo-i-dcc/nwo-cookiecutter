# In the .env file, you can set environment variables
# for your research project

#
# Environment variables
#

# Project directory (set the path to the top-level directory
# of this project, e.g.:
# PROJECT_DIR="/home/user/Projects/this_project"
# PROJECT_DATA_DIR="/home/user/Projects/this_project/data"

# Add the project python package to the PYTHONPATH
# PYTHONPATH="$PYTHONPATH:${PROJECT_DIR}/src"
